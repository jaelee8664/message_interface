{
  "name": "message-interface-tcp-load",
  "version": "1.0.0",
  "description": "TCP 프로토콜 부하 테스트 (Node.js 내장 net 모듈 사용 — 별도 설치 불필요)",
  "main": "tcp-load.js",
  "scripts": {
    "test":    "node tcp-load.js",
    "smoke":   "node tcp-load.js --vus 2   --duration 10  --ramp 0",
    "load":    "node tcp-load.js --vus 20  --duration 60  --ramp 10",
    "stress":  "node tcp-load.js --vus 100 --duration 120 --ramp 30"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
